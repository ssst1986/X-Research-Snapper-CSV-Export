{
  "manifest_version": 3,
  "name": "X Research Snapper & CSV Export",
  "version": "1.2",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {  
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.x.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": { 
    "128": "icon128.png"
  }
}